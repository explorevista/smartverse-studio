{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",

    "baseUrl": ".",

    "paths": {
      "@/*": ["./*"],
      "@/app/*": ["app/*"],
      "@/components/*": ["components/*"],
      "@/config/*": ["config/*"],
      "@/data/*": ["data/*"],
      "@/docs/*": ["docs/*"],
      "@/pages/*": ["pages/*"],
      "@/projects/*": ["projects/*"],
      "@/public/*": ["public/*"],
      "@/scripts/*": ["scripts/*"],
      "@/seo/*": ["seo/*"],
      "@/styles/*": ["styles/*"],
      "@/assets/*": ["assets/*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mjs"
  ],

  "exclude": [
    "node_modules"
  ]
}
